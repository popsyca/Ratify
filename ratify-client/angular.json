{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "ratify-client": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": { "outputPath": "dist/ratify-client", "index": "src/index.html", "browser": "src/main.ts", "polyfills": ["zone.js"], "tsConfig": "tsconfig.json", "assets": [], "styles": ["src/styles.css"] }
        },
        "serve": { "builder": "@angular-devkit/build-angular:dev-server", "options": { "proxyConfig": "proxy.conf.json" }, "configurations": { "development": { "buildTarget": "ratify-client:build" } }, "defaultConfiguration": "development" }
      }
    }
  },
  "cli": {
    "analytics": "646f8346-189b-41e2-8c72-5625083e5ac5"
  }
}
